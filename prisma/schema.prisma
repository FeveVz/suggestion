generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Service {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  icon         String   // emoji
  category     String   // "principal" or "complementario"
  whatIncludes String?  // JSON array of {icon, title, description, items[]}
  methodology  String?  // JSON array of {phase, title, description, iconBg, iconColor, iconEmoji}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  plans        Plan[]
  clients      ClientService[]
}

model Plan {
  id            String   @id @default(cuid())
  serviceId     String
  name          String
  price         Float
  originalPrice Float?
  period        String   // "/mes", "/proyecto", "(pago único)", "/evento", "por día"
  description   String
  features      String   // JSON array of strings
  badge         String?  // "Más Popular", "Premium", null
  isRecommended Boolean  @default(false)
  order         Int      @default(0)
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  selections    ClientService[]
}

model Client {
  id              String   @id @default(cuid())
  name            String
  activity        String   // rubro
  startDate       String   // fecha de inicio
  location        String
  phone           String
  email           String
  status          String   @default("pendiente")  // "pendiente" | "aceptado"
  anticipoPagado  Boolean  @default(false)
  descuento       Float    @default(0)             // monto en soles
  fechaAceptacion String?  // fecha en que se aceptó la proforma
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  services        ClientService[]
}

model ClientService {
  id             String   @id @default(cuid())
  clientId       String
  serviceId      String
  selectedPlanId String?  // plan elegido por el cliente
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  selectedPlan   Plan?    @relation(fields: [selectedPlanId], references: [id], onDelete: SetNull)

  @@unique([clientId, serviceId])
}
